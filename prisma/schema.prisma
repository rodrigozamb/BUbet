generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String             @id @default(uuid())
  name                   String
  email                  String             @unique
  password_hash          String
  created_at             DateTime           @default(now())
  username               String
  role                   Role               @default(USER)
  is_confirmed           DateTime?
  profile_url            String?
  position               Int                @default(0)
  last_activity          DateTime?
  points                 Int                @default(0)
  favorite_competitor_id String?
  bets                   Bets[]
  Feedback               Feedback[]
  GoldenBanner           GoldenBanner[]
  notifications          UserNotification[]
  favorite_competitor    Competitor?        @relation(fields: [favorite_competitor_id], references: [id])
  badges                 Badge[]            @relation("BadgeToUser")
  userSeasons            UserSeason[]
  socials                Socials[]
  cupons                 Cupons[]
  guessBets              GuessBets[]
  userAlbumCards         UserAlbumCards[]
  userAlbumPacks         UserAlbumPacks[]
  album_cards_offers     AlbumCardsTrades[] @relation("AlbumCardsTradesFromUser")
  album_cards_trades     AlbumCardsTrades[] @relation("AlbumCardsTradesToUser")

  @@map("users")
}

model Event {
  id                 String         @id @default(uuid())
  name               String
  description        String
  date               DateTime
  starts_at          DateTime
  ends_at            DateTime
  created_at         DateTime       @default(now())
  banner             String
  local              String         @default("Não Definido")
  bets               Bets[]
  eventResults       EventResults[]
  estandartes        GoldenBanner[]
  event_banner_types BannerType[]   @relation("BannerTypeToEvent")
  competitors        Competitor[]   @relation("CompetitorToEvent")
  judges             Judge[]        @relation("EventToJudge")
  socials            Socials[]
  guessBets          GuessBets[]
  albums             Album[]

  @@map("events")
}

model GuessEvent {
  id               String             @id @default(uuid())
  name             String
  description      String
  date             DateTime
  points           Int                @default(10)
  ends_at          DateTime
  created_at       DateTime           @default(now())
  bets             GuessBets[]
  guess_options    String[]
  custom_guess     Boolean            @default(false)
  eventResults     EventResults[]
  guessBetsResults GuessBetsResults[]

  @@map("guess_events")
}

model GuessBets {
  id           String      @id @default(uuid())
  userId       String
  guess        String
  custom_guess String?
  created_at   DateTime    @default(now())
  points       Int         @default(0)
  finished     Boolean     @default(false)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  guessEvent   GuessEvent? @relation(fields: [guessEventId], references: [id])
  guessEventId String?
  event        Event?      @relation(fields: [eventId], references: [id])
  eventId      String?

  @@map("guess_bets")
}

model GuessBetsResults {
  id String @id @default(uuid())

  guess        String
  custom_guess String?
  created_at   DateTime @default(now())

  guessEvent   GuessEvent? @relation(fields: [guessEventId], references: [id])
  guessEventId String?

  @@map("guess_bets_results")
}

model Competitor {
  id           String         @id @default(uuid())
  name         String
  profile_url  String
  created_at   DateTime       @default(now())
  description  String
  eventResults EventResults[]
  estandartes  GoldenBanner[]
  users        User[]
  badges       Badge[]        @relation("BadgeToCompetitor")
  events       Event[]        @relation("CompetitorToEvent")
  socials      Socials[]

  @@map("competitors")
}

model EventResults {
  eventId      String
  competitorId String
  placing      String
  created_at   DateTime     @default(now())
  score        Float
  id           String       @id @default(uuid())
  competitor   Competitor   @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  estandartes  BannerType[] @relation("BannerTypeToEventResults")
  guessEvent   GuessEvent?  @relation(fields: [guessEventId], references: [id])
  guessEventId String?

  @@map("events_results")
}

model Bets {
  userId      String
  eventId     String
  bets        String[]
  created_at  DateTime       @default(now())
  points      Int            @default(0)
  finished    Boolean        @default(false)
  id          String         @id @default(uuid())
  event       Event          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  estandartes GoldenBanner[]
  cupons      Cupons?

  @@index([userId, eventId])
  @@map("bets")
}

model Judge {
  id          String    @id @default(uuid())
  description String
  avatar      String
  first_name  String
  last_name   String
  nickname    String
  badges      Badge[]   @relation("BadgeToJudge")
  events      Event[]   @relation("EventToJudge")
  socials     Socials[]

  @@map("judges")
}

model BannerType {
  id           String         @id @default(uuid())
  name         String
  description  String
  goldenBanner GoldenBanner[]
  events       Event[]        @relation("BannerTypeToEvent")
  resultado    EventResults[] @relation("BannerTypeToEventResults")

  @@map("banner_types")
}

model GoldenBanner {
  competitorId String
  eventId      String
  bannerTypeId String
  betId        String
  userId       String
  bannerType   BannerType @relation(fields: [bannerTypeId], references: [id], onDelete: Cascade)
  bet          Bets       @relation(fields: [betId], references: [id], onDelete: Cascade)
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  event        Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([competitorId, eventId, bannerTypeId, userId], name: "id")
  @@map("golden_banners")
}

model Feedback {
  id         String   @id @default(uuid())
  userId     String
  content    String
  created_at DateTime @default(now())
  image      String?
  verified   Boolean  @default(false)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("feedbacks")
}

model Notification {
  id                String             @id @default(uuid())
  title             String
  content           String
  icon              String?
  created_at        DateTime           @default(now())
  link              String?
  userNotifications UserNotification[]

  @@map("notifications")
}

model UserNotification {
  id             String       @id @default(uuid())
  is_visualized  DateTime?
  created_at     DateTime     @default(now())
  userId         String
  notificationId String
  notification   Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_notifications")
}

model Badge {
  id          String       @id @default(uuid())
  created_at  DateTime     @default(now())
  name        String
  description String
  image_url   String
  competitors Competitor[] @relation("BadgeToCompetitor")
  judges      Judge[]      @relation("BadgeToJudge")
  users       User[]       @relation("BadgeToUser")

  @@map("badges")
}

model Season {
  id          String       @id @default(uuid())
  name        String
  created_at  DateTime     @default(now())
  userSeasons UserSeason[]

  @@map("seasons")
}

model UserSeason {
  id       String @id @default(uuid())
  userId   String
  seasonId String
  points   Int    @default(0)
  position Int    @default(0)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  season   Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)

  @@map("user_seasons")
}

model Socials {
  id           String      @id @default(uuid())
  type         SocialType
  name         String
  user         User?       @relation(fields: [userId], references: [id])
  userId       String?
  event        Event?      @relation(fields: [eventId], references: [id])
  eventId      String?
  competitor   Competitor? @relation(fields: [competitorId], references: [id])
  competitorId String?
  judge        Judge?      @relation(fields: [judgeId], references: [id])
  judgeId      String?

  @@map("socials")
}

model Cupons {
  id    String @id @default(uuid())
  value Int

  created_at DateTime  @default(now())
  used_at    DateTime?

  user   User   @relation(fields: [userId], references: [id])
  userId String

  bet   Bets?   @relation(fields: [betId], references: [id], onDelete: Cascade)
  betId String? @unique

  @@map("cupons")
}

model Album {
  id          String       @id @default(uuid())
  name        String
  description String
  pages       AlbumPage[]
  albumCards  AlbumCards[]

  event     Event?     @relation(fields: [event_id], references: [id])
  event_id  String?
  cardPacks CardPack[]

  @@map("albums")
}

model AlbumPage {
  id      String @id @default(uuid())
  albumId String
  index   Int    @default(0)

  type        AlbumPageType
  cards       AlbumCards[]
  description String?

  album Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  @@map("album_pages")
}

model AlbumCards {
  id       String @id @default(uuid())
  albumId  String
  name     String
  imageUrl String
  naipe    String
  team     String @default("Desconhecido")

  album          Album            @relation(fields: [albumId], references: [id], onDelete: Cascade)
  album_page     AlbumPage?       @relation(fields: [album_page_id], references: [id])
  album_page_id  String?
  userAlbumCards UserAlbumCards[]

  albumCardsOffers AlbumCardsTrades[] @relation("OfferedCard")
  albumCardsTrades AlbumCardsTrades[] @relation("TradeCard")

  @@map("album_cards")
}

model UserAlbumCards {
  id               String   @id @default(uuid())
  user_id          String
  album_card_id    String
  obtained_at      DateTime @default(now())
  last_obtained_at DateTime @default(now())

  quantity Int @default(1)

  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  album_card AlbumCards @relation(fields: [album_card_id], references: [id], onDelete: Cascade)

  @@map("user_album_cards")
}

model UserAlbumPacks {
  id String @id @default(uuid())

  user_id      String
  card_pack_id String

  obtained_at      DateTime @default(now())
  last_obtained_at DateTime @default(now())

  quantity Int @default(1)

  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  card_pack CardPack @relation(fields: [card_pack_id], references: [id], onDelete: Cascade)

  @@unique([user_id, card_pack_id])
  @@map("user_album_packs")
}

model CardPack {
  id          String  @id @default(uuid())
  available   Boolean @default(true)
  name        String
  description String
  image_url   String

  album          Album            @relation(fields: [album_id], references: [id], onDelete: Cascade)
  album_id       String
  userAlbumPacks UserAlbumPacks[]

  @@map("card_packs")
}

model AlbumCardsTrades {
  id         String    @id @default(uuid())
  created_at DateTime  @default(now())
  traded_at  DateTime?

  from_user    User   @relation("AlbumCardsTradesFromUser", fields: [from_user_id], references: [id], onDelete: Cascade)
  from_user_id String

  to_user    User?  @relation("AlbumCardsTradesToUser", fields: [to_user_id], references: [id], onDelete: Cascade)
  to_user_id String?

  offered_card     AlbumCards @relation("OfferedCard", fields: [offered_card_id], references: [id], onDelete: Cascade)
  offered_card_id  String
  offered_quantity Int        @default(1)

  trade_card     AlbumCards @relation("TradeCard", fields: [trade_card_id], references: [id], onDelete: Cascade)
  trade_card_id  String
  trade_quantity Int        @default(1)

  @@map("album_cards_trades")
}

enum Role {
  USER
  ADMIN
}

enum SocialType {
  YOUTUBE
  INSTAGRAM
}

enum BetType {
  RANKING
  GUESS
}

enum AlbumPageType {
  DESCRIPTION
  IMAGESL
  IMAGESR
}
